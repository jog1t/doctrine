{
  "name": "doctrine",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "pnpm --filter @doctrine/server dev",
    "dev:client": "pnpm --filter @doctrine/client dev",
    "build": "pnpm --filter @doctrine/shared build && pnpm --filter @doctrine/server build && pnpm --filter @doctrine/client build",
    "typecheck": "tsc --noEmit -p server/tsconfig.json && tsc --noEmit -p client/tsconfig.json",
    "lint": "oxlint .",
    "format": "oxfmt ."
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "oxfmt": "^0.40.0",
    "oxlint": "latest",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cbor-extract",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
